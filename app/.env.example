# Базовая конфигурация
# ⚠️ Никогда не коммитьте .env файлы в git (кроме .env.example)

# URL PocketBase (локальный dev, staging или production)
# Dev: http://localhost:8090
# Staging/Prod: https://api.knok-knok.ru:8443
VITE_PB_URL=http://localhost:8090

# Секреты для локальной генерации типов (не попадут в Git)
# Скопируйте файл в .env и заполните пароль
PB_TYPEGEN_URL=http://192.168.1.xxx:8090
PB_TYPEGEN_EMAIL=my@mail.com
PB_TYPEGEN_PASSWORD=your_super_secret_password
