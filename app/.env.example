# Базовая конфигурация
# ⚠️ Никогда не коммитьте .env файлы в git (кроме .env.example)

# URL Supabase (локальный mock, staging или production)
VITE_SUPABASE_URL=

# Anon key для доступа к Supabase
VITE_SUPABASE_ANON_KEY=

# Режим разработки: true = mock (in-memory), false = реальная БД
VITE_USE_MOCK=true

# Для seed-скриптов (не для client!)
# Service role key нужен только для скриптов наполнения БД
SUPABASE_SERVICE_ROLE_KEY=

# Пароль postgres для генерации типов и миграций
SUPABASE_CLI_PASSWORD=

# IP домашнего сервера (внутри VPN, например 10.0.0.X или 192.168.1.X)
# Заполняется только для staging/production окружений
SUPABASE_HOME_IP_ADDRESS=

# JWT Secret (должен совпадать с конфигом Supabase)
JWT_SECRET=
